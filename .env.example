# ── Google OAuth 2.0 (for GDrive access) ────────────────────────────────────
# Create at: console.cloud.google.com → APIs & Services → Credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8000/auth/callback

# ── Gemini / Google AI ───────────────────────────────────────────────────────
# Shared on backend — never exposed to the mobile app
# Get your key at: aistudio.google.com
GOOGLE_GENAI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# ── Vertex AI Agent Builder (GenAI App Builder) ──────────────────────────────
# Requires a GCP project with billing enabled and these APIs enabled:
#   - aiplatform.googleapis.com
#   - discoveryengine.googleapis.com
GOOGLE_CLOUD_PROJECT=
VERTEX_AI_LOCATION=us-central1
VERTEX_AI_RAG_CORPUS=  # resource name — filled automatically on first run

# ── GCP Service Account ──────────────────────────────────────────────────────
# Download from: IAM → Service Accounts → Keys → Add Key → JSON
# Place the file as sa.json in the project root
GOOGLE_APPLICATION_CREDENTIALS=./sa.json

# ── GDrive ───────────────────────────────────────────────────────────────────
GDRIVE_ROOT_FOLDER_NAME=co-scienza
GDRIVE_ROOT_FOLDER_ID=  # filled automatically on first run

# ── Celery / Redis ───────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0        # use redis://localhost:6379/0 for local dev

# ── App ──────────────────────────────────────────────────────────────────────
SECRET_KEY=change-me-to-a-random-string
DATABASE_URL=sqlite+aiosqlite:///./data/coscienza.db
DATA_DIR=./data
